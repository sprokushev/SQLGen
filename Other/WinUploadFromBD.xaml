<Window x:Name="winUploadFromBD" x:Class="SQLGen.WinUploadFromBD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinUploadFromBD" Height="810" Width="1000" Activated="winUploadFromBD_Activated" Closed="winUploadFromBD_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">
        <Label Content="Подключение:" Margin="12,2,0,0" HorizontalAlignment="Left" Width="93" VerticalAlignment="Top" Height="26"/>
        <ComboBox x:Name="cbConnectSQL" HorizontalAlignment="Left" Margin="105,4,0,0" Width="512" SelectionChanged="cbConnect_SelectionChanged" Height="22" VerticalAlignment="Top"/>

        <Label Content="Поиск:" Margin="13,29,0,0" HorizontalAlignment="Left" Width="46" VerticalAlignment="Top" Height="26"/>
        <local:HistoryTextBox x:Name="tbFilter" Margin="63,30,0,0" KeyDown="tbFilter_KeyDown" LostFocus="tbFilter_LostFocus" Height="23" VerticalAlignment="Top" HorizontalAlignment="Left" Width="441" SelectionChanged="tbFilter_SelectionChanged"/>

        <Button x:Name="btFind" Content="Найти" Margin="512,31,0,0" VerticalAlignment="Top" Click="btFind_Click" HorizontalAlignment="Left" Width="105"/>

        <Label Content="Результат поиска:" Margin="13,71,0,0" HorizontalAlignment="Left" Width="107" Height="26" VerticalAlignment="Top"/>
        <CheckBox x:Name="addTables" Content="Добавить таблицы" HorizontalAlignment="Left" Margin="140,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addForeignTables" Content="Добавить внешние таблицы" HorizontalAlignment="Left" Margin="284,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addViews" Content="Добавить представления" HorizontalAlignment="Left" Margin="480,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addProcs" Content="Добавить процедуры и функции (SQL)" HorizontalAlignment="Left" Margin="670,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addTriggers" Content="Добавить триггеры" HorizontalAlignment="Left" Margin="140,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addSequences" Content="Добавить сиквенсы" HorizontalAlignment="Left" Margin="284,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addIndexes" Content="Добавить индексы" HorizontalAlignment="Left" Margin="480,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addProcsNotSQL" Content="Добавить процедуры и функции (не SQL)" HorizontalAlignment="Left" Margin="670,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>

        <DataGrid x:Name="dgResults" Margin="10,105,10,0" VerticalScrollBarVisibility="Visible" ItemsSource="{Binding ListResults}" AutoGenerateColumns="False" MouseDoubleClick="dgResults_MouseDoubleClick" Height="204" VerticalAlignment="Top" IsReadOnly="True" CanUserDeleteRows="False" CanUserAddRows="False" >
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="Type" Header="Тип" Width="140" Binding="{Binding Path=Type}" IsReadOnly="true"/>
                <DataGridTextColumn x:Name="FullName" Header="Наименование" Width="500" Binding="{Binding Path=FullName}" IsReadOnly="true"/>
                <DataGridTextColumn x:Name="isAutogen" Header="Автогенная" Width="100" Binding="{Binding Path=isAutogen}" IsReadOnly="true"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить в список" Click="btAdd_Click" />
                    <MenuItem Header="Посмотреть текст хранимки" Click="btView_Click" />
                    <MenuItem Header="Посмотреть оригинальный текст хранимки" Click="btViewOriginal_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <Label Content="Список объектов:" HorizontalAlignment="Left" Margin="10,314,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btClear" Content="Очистить" Margin="130,317,0,0" Click="btClear_Click" HorizontalAlignment="Left" Width="85" Height="20" VerticalAlignment="Top"/>
        <Button x:Name="btAdd" Content="Добавить выбранное" HorizontalAlignment="Left" Margin="238,317,0,0" VerticalAlignment="Top" Width="170" Click="btAdd_Click"/>
        <Button x:Name="btAddAll" Content="Добавить ВСЕ" HorizontalAlignment="Left" Margin="431,317,0,0" VerticalAlignment="Top" Width="128" Click="btAddAll_Click"/>

        <TextBox x:Name="tbObjects" Margin="10,351,10,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" AcceptsReturn="True" Height="290" VerticalAlignment="Top" />

        <Grid Margin="20,0,20,110" VerticalAlignment="Bottom">
            <ProgressBar Name="pbStatus" Minimum="0" Maximum="100" Height="20"/>
            <TextBlock Text="{Binding ElementName=pbStatus, Path=Value, StringFormat={}{0:0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Label Content="Каталог:" HorizontalAlignment="Left" Margin="16,0,0,80" Height="26" VerticalAlignment="Bottom"/>
        <TextBox x:Name="tbFolder" HorizontalAlignment="Left" Height="23" Margin="80,0,0,80" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="355"/>
        <Button x:Name="btFolder" Content="Выбрать" HorizontalAlignment="Left" Height="23" Margin="450,0,0,80" VerticalAlignment="Bottom" Width="210" Click="btTFolder_Click"/>

        <CheckBox x:Name="checkNewdb" Content="добавить теги пропуска" HorizontalAlignment="Left" Margin="16,0,0,60" VerticalAlignment="Bottom" Width="Auto" Height="15"/>
        <CheckBox x:Name="checkIndexCreate" Content="Индексы CREATE INDEX" HorizontalAlignment="Left" Margin="186,0,0,60" VerticalAlignment="Bottom" Width="Auto" Height="15" Visibility="Visible"/>
        <CheckBox x:Name="checkAddRegion" Content="Добавлять проверку на региональность для объектов из схем rXXX" HorizontalAlignment="Left" Margin="16,0,0,41.4" VerticalAlignment="Bottom" Width="Auto" Height="15"/>

        <Label Content="Проект GIT:" Margin="10,0,0,11" Height="26" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="73"/>
        <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="88,0,0,11" VerticalAlignment="Bottom" Width="300"/>
        <Button x:Name="btUpload" Content="Выгрузить для задачи" Margin="450,0,0,56" Click="btUpload_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Bottom"/>
        <Button x:Name="btUploadDEV" Content="Выгрузить для DEV (разработка)" Margin="450,0,0,32" Click="btUploadDEV_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Bottom"/>
        <Button x:Name="btUploadGIT" Content="Выгрузить для &quot;старых&quot; проектов" Margin="680,0,0,32" Click="btUploadGIT_Click" HorizontalAlignment="Left" Width="252" VerticalAlignment="Bottom"/>
        <Button x:Name="btCancel" Content="Остановить" Margin="450,0,0,8" Click="btCancel_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
