<Window x:Name="winChangesetInGIT" x:Class="SQLGen.WinChangesetInGIT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinChangesetInGIT" Height="700" Width="1000" Activated="winChangesetInGIT_Activated" Closed="winChangesetInGIT_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">
        <Label Content="Проект GIT:" HorizontalAlignment="Left" Margin="12,2,0,0" Height="26" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="105,4,0,0" VerticalAlignment="Top" Width="300" Height="23" SelectionChanged="cbGITProject_SelectionChanged"/>
        <Label x:Name="lbGITBranch" Content="Текущая ветка GIT:" HorizontalAlignment="Left" Margin="450,2,0,0" VerticalAlignment="Top" Width="Auto"/>
        <Button x:Name="btChangeBranch" Content="------------" Margin="583,4,0,0" VerticalAlignment="Top" Click="btChangeBranch_Click" HorizontalAlignment="Left" Width="211"/>
        <Button x:Name="btGitPull" Content="GIT PULL" Margin="803,4,0,0" VerticalAlignment="Top" Click="btGitPull_Click" HorizontalAlignment="Left" Width="100"/>

        <Label Content="Маска изменяемых файлов:" HorizontalAlignment="Left" Margin="14,37,0,0" Height="26" VerticalAlignment="Top"/>
        <TextBox x:Name="tbMask" HorizontalAlignment="Left" Height="24" Margin="205,38,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="562" ToolTip="Примеры: E:\Projects\dev_promed_pg\dbo\TABLE\*.sql - все файлы *.sql в данном каталоге; E:\Projects\dev_promed_pg\*\TABLE\*.sql - все файлы *.sql во всех папках TABLE"/>
        <Button x:Name="btFolder" Content="Выбрать каталог" HorizontalAlignment="Left" Height="24" Margin="787,39,0,0" VerticalAlignment="Top" Width="174" Click="btFolder_Click"/>

        <Label Content="Исключаемые каталоги:" HorizontalAlignment="Left" Margin="14,67,0,0" Height="26" VerticalAlignment="Top"/>
        <TextBox x:Name="tbExclude" Margin="205,68,233,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" AcceptsReturn="True" Height="73" VerticalAlignment="Top" ToolTip="Можно несколько через запятую. Примеры: E:\Projects\dev_promed_pg\data - исключить все файлы в данном каталоге; E:\Projects\dev_promed_pg\*\TABLE - исключить все файлы во всех папках TABLE"/>
        <Button x:Name="btExclude" Content="Выбрать каталог" HorizontalAlignment="Left" Height="24" Margin="787,69,0,0" VerticalAlignment="Top" Width="174" Click="btExclude_Click"/>

        <Label Content="Найти:" Margin="17,255,0,0" HorizontalAlignment="Left" Width="108" Height="26" VerticalAlignment="Top"/>
        <Rectangle Fill="#FFE5E5E5" HorizontalAlignment="Left" Height="73" Margin="17,283,0,0" Stroke="Black" VerticalAlignment="Top" Width="311"/>
        <RadioButton x:Name="rbSearchStartsWith" GroupName="Search" Content="Строка начинается с" HorizontalAlignment="Left" Margin="27,289,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbSearchContains" GroupName="Search" Content="Строка содержит фразу" HorizontalAlignment="Left" Margin="27,309,0,0" VerticalAlignment="Top" Checked="rbSearchContains_Checked" Unchecked="rbSearchContains_Unchecked"/>
        <RadioButton x:Name="rbSearchEndsWith" GroupName="Search" Content="Строка заканчивается на" HorizontalAlignment="Left" Margin="27,329,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="tbSearch" Margin="339,283,19,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" AcceptsReturn="True" Height="73" VerticalAlignment="Top"/>

        <Label Content="Заменить:" Margin="17,367,0,0" HorizontalAlignment="Left" Width="87" VerticalAlignment="Top" Height="26" RenderTransformOrigin="7.87,9.982"/>
        <Rectangle Fill="#FFE5E5E5" HorizontalAlignment="Left" Height="156" Margin="18,392,0,0" Stroke="Black" VerticalAlignment="Top" Width="310"/>
        <RadioButton x:Name="rbReplaceAll" GroupName="Replace" Content="Заменить всю строку на" HorizontalAlignment="Left" Margin="27,405,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbReplace" GroupName="Replace" Content="Заменить найденную фразу на фразу" HorizontalAlignment="Left" Margin="27,425,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbReplaceAddStart" GroupName="Replace" Content="Добавить в начало строки" HorizontalAlignment="Left" Margin="27,445,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbReplaceAddEnd" GroupName="Replace" Content="Добавить в конец строки" HorizontalAlignment="Left" Margin="27,465,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbInsertBefore" GroupName="Replace" Content="Добавить перед найденной строкой" HorizontalAlignment="Left" Margin="27,485,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbInsertAfter" GroupName="Replace" Content="Добавить после найденной строки" HorizontalAlignment="Left" Margin="27,505,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbDelete" GroupName="Replace" Content="Удалить найденную строку" HorizontalAlignment="Left" Margin="27,525,0,0" VerticalAlignment="Top" Checked="rbDelete_Checked" Unchecked="rbDelete_Unchecked"/>

        <TextBox x:Name="tbReplace" Margin="339,404,19,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" AcceptsReturn="True" Height="117" VerticalAlignment="Top" />

        <Grid Margin="21,564,19,0" VerticalAlignment="Top">
            <ProgressBar Name="pbStatus" Minimum="0" Maximum="100" Height="20"/>
            <TextBlock Text="{Binding ElementName=pbStatus, Path=Value, StringFormat={}{0:0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Button x:Name="btChange" Content="Изменить скрипты" Margin="223,608,0,0" Click="btChange_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Top"/>
        <Button x:Name="btCancel" Content="Остановить" Margin="535,608,0,0" Click="btCancel_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Top"/>
        <Label Content="Файл содержит фразу:" HorizontalAlignment="Left" Margin="14,187,0,0" Height="26" VerticalAlignment="Top"/>
        <TextBox x:Name="tbFileContains" HorizontalAlignment="Left" Height="24" Margin="205,188,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="776" ToolTip="Примеры: E:\Projects\dev_promed_pg\dbo\TABLE\*.sql - все файлы *.sql в данном каталоге; E:\Projects\dev_promed_pg\*\TABLE\*.sql - все файлы *.sql во всех папках TABLE"/>
        <Label Content="Файл НЕ содержит фразу:" HorizontalAlignment="Left" Margin="14,216,0,0" Height="26" VerticalAlignment="Top"/>
        <TextBox x:Name="tbFileNotContains" HorizontalAlignment="Left" Height="24" Margin="205,217,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="776" ToolTip="Примеры: E:\Projects\dev_promed_pg\dbo\TABLE\*.sql - все файлы *.sql в данном каталоге; E:\Projects\dev_promed_pg\*\TABLE\*.sql - все файлы *.sql во всех папках TABLE"/>
        <CheckBox x:Name="cbCaseSensitivity" Content="Учитывать регистр" HorizontalAlignment="Left" Margin="27,157,0,0" VerticalAlignment="Top" IsChecked="False"/>
        <CheckBox x:Name="cbRegex" Content="Regular Expression" HorizontalAlignment="Left" Margin="193,309,0,0" VerticalAlignment="Top" IsChecked="False"/>

    </Grid>
</Window>
