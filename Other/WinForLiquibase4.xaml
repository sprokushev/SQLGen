<Window x:Name="winForLiquibase4" x:Class="SQLGen.WinForLiquibase4"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinForLiquibase4" Height="230" Width="1000" Activated="winForLiquibase4_Activated" Closed="winForLiquibase4_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">
        <Label Content="Проект GIT:" HorizontalAlignment="Left" Margin="12,2,0,0" Height="26" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="105,4,0,0" VerticalAlignment="Top" Width="300" Height="23" SelectionChanged="cbGITProject_SelectionChanged"/>
        <Label x:Name="lbGITBranch" Content="Текущая ветка GIT:" HorizontalAlignment="Left" Margin="450,2,0,0" VerticalAlignment="Top" Width="Auto"/>
        <Button x:Name="btChangeBranch" Content="------------" Margin="583,4,0,0" VerticalAlignment="Top" Click="btChangeBranch_Click" HorizontalAlignment="Left" Width="211"/>
        <Button x:Name="btGitPull" Content="GIT PULL" Margin="803,4,0,0" VerticalAlignment="Top" Click="btGitPull_Click" HorizontalAlignment="Left" Width="100"/>

        <Label Content="Изменяемый yml-файл" HorizontalAlignment="Left" Margin="14,37,0,0" Height="26" VerticalAlignment="Top"/>
        <TextBox x:Name="tbYMLFile" HorizontalAlignment="Left" Height="24" Margin="205,38,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="562"/>
        <Button x:Name="btOpen" Content="Выбрать yml-файл" HorizontalAlignment="Left" Height="24" Margin="787,39,0,0" VerticalAlignment="Top" Width="174" Click="btOpen_Click"/>

        <CheckBox x:Name="cbIncludeTask" Content="Включая изменение вложенных yml-файлов задач ?" HorizontalAlignment="Left" Margin="205,67,0,0" VerticalAlignment="Top" IsChecked="True"/>
        <CheckBox x:Name="cbIncludePrevVersion" Content="Включая изменение вложенных yml-файлов предыдущих версий ?" HorizontalAlignment="Left" Margin="205,85,0,0" VerticalAlignment="Top" IsChecked="True"/>

        <RadioButton x:Name="rbLiquibase3" GroupName="Liquibase" Content="Совместимость с Liquibase 3" HorizontalAlignment="Left" Margin="205,105,0,0" VerticalAlignment="Top"/>
        <RadioButton x:Name="rbLiquibase4" GroupName="Liquibase" Content="Совместимость с Liquibase 4" HorizontalAlignment="Left" Margin="405,105,0,0" VerticalAlignment="Top" IsChecked="True"/>

        <Button x:Name="btChange" Content="Изменить" Margin="381,150,0,0" Click="btChange_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Top"/>
    </Grid>
</Window>
