<Window x:Class="SQLGen.WinExecute"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d" Height="800" Width="1000" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown" Closed="Window_Closed" Activated="Window_Activated">
    <Grid x:Name="mainGrid" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid Margin="10,5,10,0" VerticalAlignment="Top">
            <ProgressBar Name="pbStatus" Minimum="0" Maximum="100" Height="20"/>
            <TextBlock Text="{Binding ElementName=pbStatus, Path=Value, StringFormat={}{0:0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
        <Label Content="Команда:" HorizontalAlignment="Left" Margin="10,30,0,0" VerticalAlignment="Top" Width="60"/>
        <TextBox x:Name="tbCommand" Height="23" Margin="80,30,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="896" IsReadOnly="True" />
        <DockPanel Margin="10,65,0,0">
            <ToolBar DockPanel.Dock="Top" TabIndex="2" Background="#00FFFFFF">
                <ComboBox Name="cbInfoFontFamily" Width="150" Focusable="False" IsTabStop="False" TabIndex="3" />
                <ComboBox Name="cbInfoFontSize" Width="50" IsEditable="True" Focusable="False" IsTabStop="False" TabIndex="4" />
            </ToolBar>
            <RichTextBox x:Name="tbInfo" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True" ScrollViewer.CanContentScroll="True" Margin="0,0,0,40" PreviewKeyDown="tbInfo_PreviewKeyDown">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0" />
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>

        </DockPanel>
        <Button x:Name="btOk" Content="Закрыть" Margin="240,0,239,10" Height="20" VerticalAlignment="Bottom" MinWidth="72" MinHeight="20" Width="72" Click="btOk_Click"/>
    </Grid>
</Window>
