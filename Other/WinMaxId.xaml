<Window x:Name="winMaxId" x:Class="SQLGen.WinMaxId"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="Определить максимальное значение поля в таблице" Height="564" Width="920" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen" Activated="winMaxId_Activated" Closed="winMaxId_Closed" >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">

        <Label Content="Таблица:" HorizontalAlignment="Left" Margin="12,10,0,0" Height="24" VerticalAlignment="Top"/>
        <local:HistoryTextBox x:Name="tbTable" Height="24" Margin="166,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="257" KeyDown="tbTable_KeyDown" SelectionChanged="tbTable_SelectionChanged" LostFocus="tbTable_LostFocus"/>
        <Label Content="Поле:" HorizontalAlignment="Left" Margin="425,10,0,0" Height="24" VerticalAlignment="Top"/>
        <TextBox x:Name="tbPK" Height="24" Margin="471,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="253" LostFocus="tbPK_LostFocus"/>

        <Label Content="Проект GIT:" Margin="14,63,0,0" Height="26" VerticalAlignment="Top" HorizontalAlignment="Left" Width="124"/>
        <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="166,67,0,0" VerticalAlignment="Top" Width="257" SelectionChanged="cbGITProject_SelectionChanged"/>

        <Label Content="Подключения:" HorizontalAlignment="Left" Margin="14,98,0,0" Height="25" VerticalAlignment="Top" Width="95"/>
        <TextBox x:Name="tbConnections" HorizontalAlignment="Left" Margin="166,94,0,0" Width="443" VerticalAlignment="Top" Height="115" IsEnabled="False" VerticalScrollBarVisibility="Visible" TextChanged="tbConnections_TextChanged" />
        <Button x:Name="btConnections" Content="Выбрать" HorizontalAlignment="Left" Margin="616,96,0,0" VerticalAlignment="Top" Width="79" Height="25" Click="btConnections_Click" />

        <Label Content="Значение не более:" HorizontalAlignment="Left" Margin="14,34,0,0" Height="24" VerticalAlignment="Top" Width="124"/>
        <TextBox x:Name="tbUpper" HorizontalAlignment="Left" Margin="166,39,0,0" Width="257" VerticalAlignment="Top" Height="24" LostFocus="tbUpper_LostFocus" />

        <Label Content="Запрос:" HorizontalAlignment="Left" Margin="12,215,0,0" Height="25" VerticalAlignment="Top" Width="124"/>
        <TextBox x:Name="tbSQL" HorizontalAlignment="Left" Margin="166,215,0,0" Width="728" VerticalAlignment="Top" Height="24" TextChanged="tbSQL_TextChanged" />

        <Label Content="Максимальное значение:" HorizontalAlignment="Left" Margin="12,243,0,0" Height="25" VerticalAlignment="Top" Width="149"/>
        <TextBox x:Name="tbMaxId" HorizontalAlignment="Left" Margin="166,244,0,0" Width="257" VerticalAlignment="Top" Height="24"  />
        <Button x:Name="btCount" Content="Посчитать" HorizontalAlignment="Left" Margin="428,244,0,0" VerticalAlignment="Top" Width="80" Height="25" Click="btCount_Click" />

        <DataGrid x:Name="dgSearchGrid" Margin="0,274,0,40" RowHeight="20" IsReadOnly="True" SelectionMode="Single" CanUserSortColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" VerticalScrollBarVisibility="Visible" SelectionUnit="Cell" />

    </Grid>
</Window>
