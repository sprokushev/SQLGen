<Window x:Name="winUploadFromGIT" x:Class="SQLGen.WinUploadFromGIT"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinUploadFromGIT" Height="800" Width="1000" Activated="winUploadFromGIT_Activated" Closed="winUploadFromGIT_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5" Height="784" VerticalAlignment="Top">
        <Label Content="Проект GIT:" HorizontalAlignment="Left" Margin="12,2,0,0" Height="26" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="105,4,0,0" VerticalAlignment="Top" Width="300" Height="23" SelectionChanged="cbGITProject_SelectionChanged"/>
        <Label x:Name="lbGITBranch" Content="Текущая ветка GIT:" HorizontalAlignment="Left" Margin="450,2,0,0" VerticalAlignment="Top" Width="Auto"/>
        <Button x:Name="btChangeBranch" Content="------------" Margin="583,4,0,0" VerticalAlignment="Top" Click="btChangeBranch_Click" HorizontalAlignment="Left" Width="211"/>
        <Button x:Name="btGitPull" Content="GIT PULL" Margin="803,4,0,0" VerticalAlignment="Top" Click="btGitPull_Click" HorizontalAlignment="Left" Width="100"/>

        <Label Content="Поиск:" Margin="13,29,0,0" HorizontalAlignment="Left" Width="46" VerticalAlignment="Top" Height="26"/>
        <local:HistoryTextBox x:Name="tbFilter" Margin="63,30,0,0" KeyDown="tbFilter_KeyDown" LostFocus="tbFilter_LostFocus" Height="23" VerticalAlignment="Top" HorizontalAlignment="Left" Width="441" SelectionChanged="tbFilter_SelectionChanged"/>

        <Button x:Name="btFind" Content="Найти" Margin="512,31,0,0" VerticalAlignment="Top" Click="btFind_Click" HorizontalAlignment="Left" Width="105"/>

        <Label Content="Результат поиска:" Margin="13,71,0,0" HorizontalAlignment="Left" Width="107" Height="26" VerticalAlignment="Top"/>
        <CheckBox x:Name="addTables" Content="Добавить таблицы" HorizontalAlignment="Left" Margin="140,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addViews" Content="Добавить представления" HorizontalAlignment="Left" Margin="284,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addProcs" Content="Добавить процедуры и функции" HorizontalAlignment="Left" Margin="470,58,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addTriggers" Content="Добавить триггеры" HorizontalAlignment="Left" Margin="140,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addSequences" Content="Добавить сиквенсы" HorizontalAlignment="Left" Margin="284,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>
        <CheckBox x:Name="addMarkers" Content="Добавить маркеры" HorizontalAlignment="Left" Margin="470,78,0,0" VerticalAlignment="Top" Width="Auto" Height="15"/>

        <DataGrid x:Name="dgResults" Margin="10,105,10,0" VerticalScrollBarVisibility="Visible" ItemsSource="{Binding ListResults}" AutoGenerateColumns="False" MouseDoubleClick="dgResults_MouseDoubleClick" Height="204" VerticalAlignment="Top" IsReadOnly="True" CanUserDeleteRows="False" CanUserAddRows="False" >
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="Filename" Header="Файл" Width="400" Binding="{Binding Path=sql}" IsReadOnly="true"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить в список" Click="btAdd_Click" />
                    <MenuItem Header="Посмотреть содержимое файла" Click="btView_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <Label Content="Список объектов:" HorizontalAlignment="Left" Margin="10,314,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btClear" Content="Очистить" Margin="130,317,0,0" Click="btClear_Click" HorizontalAlignment="Left" Width="85" Height="20" VerticalAlignment="Top"/>
        <Button x:Name="btAdd" Content="Добавить выбранное" HorizontalAlignment="Left" Margin="238,317,0,0" VerticalAlignment="Top" Width="170" Click="btAdd_Click"/>
        <Button x:Name="btAddAll" Content="Добавить ВСЕ" HorizontalAlignment="Left" Margin="431,317,0,0" VerticalAlignment="Top" Width="128" Click="btAddAll_Click"/>

        <TextBox x:Name="tbObjects" Margin="10,351,10,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Visible" AcceptsReturn="True" Height="290" VerticalAlignment="Top" />

        <Grid Margin="20,0,20,110" VerticalAlignment="Bottom">
            <ProgressBar Name="pbStatus" Minimum="0" Maximum="100" Height="20"/>
            <TextBlock Text="{Binding ElementName=pbStatus, Path=Value, StringFormat={}{0:0}%}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Label Content="Каталог:" HorizontalAlignment="Left" Margin="16,0,0,80" Height="26" VerticalAlignment="Bottom"/>
        <TextBox x:Name="tbFolder" HorizontalAlignment="Left" Height="23" Margin="80,0,0,80" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="355"/>
        <Button x:Name="btFolder" Content="Выбрать каталог" HorizontalAlignment="Left" Height="23" Margin="450,0,0,80" VerticalAlignment="Bottom" Width="210" Click="btTFolder_Click"/>
        <Button x:Name="btUpload" Content="Скопировать скрипты" Margin="450,0,0,56" Click="btUpload_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Bottom"/>
        <Button x:Name="btCancel" Content="Остановить" Margin="450,0,0,31" Click="btCancel_Click" HorizontalAlignment="Left" Width="210" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
