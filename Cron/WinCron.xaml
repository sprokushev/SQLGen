<Window x:Name="winCron" x:Class="SQLGen.WinCron"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinCron" Height="800" Width="1800" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen" Activated="winCron_Activated" Closed="winCron_Closed" >
    <Grid x:Name="mainGrid">
        <TabControl x:Name="tabControl">
            <TabItem x:Name="tiCronMS" Header="Задания для MS SQL (Промед)" KeyDown="tiCronMS_KeyDown" GotFocus="tiCronMS_GotFocus">
                <Grid Background="#FFE5E5E5">
                    <Button x:Name="btUpMS" ToolTip="Поднять строку выше" Click="btUpMS_Click" HorizontalAlignment="Left" Margin="10,12,0,0" VerticalAlignment="Top" Width="23" Height="23">
                        <Image Source="../Images/up.png"></Image>
                    </Button>

                    <Button x:Name="btDownMS" ToolTip="Опустить строку ниже" Click="btDownMS_Click" HorizontalAlignment="Left" Margin="40,12,0,0" VerticalAlignment="Top" Width="23" Height="23">
                        <Image Source="../Images/down.png"></Image>
                    </Button>

                    <Button x:Name="btChooseMS" Content="Выбрать" HorizontalAlignment="Left" Margin="70,10,0,0" Width="130" Height="25" VerticalAlignment="Top" Click="btChoose_Click"/>
                    <Button x:Name="btAddMS" Content="Добавить" HorizontalAlignment="Left" Margin="210,10,0,0" Width="130" Height="25" VerticalAlignment="Top" Click="btAdd_Click"/>
                    <Button x:Name="btCopyMS" Content="Клонировать" HorizontalAlignment="Left" Margin="350,10,0,0" Width="90" Height="25" VerticalAlignment="Top" Click="btCopy_Click" />
                    <Button x:Name="btEditMS" Content="Изменить" HorizontalAlignment="Left" Margin="450,10,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btEdit_Click"/>
                    <Button x:Name="btDelMS" Content="Удалить" HorizontalAlignment="Left" Margin="540,10,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btDel_Click" />
                    <Button x:Name="btGenJSON_MS" Content="Сгенерировать и сохранить JSON (F8)" HorizontalAlignment="Left" Margin="630,10,0,0" Width="300" Height="25" VerticalAlignment="Top" Click="btGenJSON_MS_Click"/>

                    <Label Content="Фильтр:" HorizontalAlignment="Left" Margin="10,40,0,0" Height="24" VerticalAlignment="Top"/>
                    <local:HistoryTextBox x:Name="tbFilterMS" HorizontalAlignment="Left" Height="24" Margin="70,40,0,0" VerticalAlignment="Top" Width="416" KeyDown="tbFilterMS_KeyDown" SelectionChanged="tbFilterMS_SelectionChanged" LostFocus="tbFilterMS_LostFocus" DropDownClosed="tbFilterMS_DropDownClosed"/>
                    <Button x:Name="btDelFilterMS" Content="X" HorizontalAlignment="Left" Height="23" Margin="493,40,0,0" VerticalAlignment="Top" Width="23" Click="btDelFilterMS_Click" ToolTip="Очистить фильтр"/>
                    <Button x:Name="btFilterMS" Content="Искать" HorizontalAlignment="Left" Margin="540,39,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btFilterMS_Click"/>

                    <DataGrid x:Name="dgCronMS"
                        AutoGenerateColumns="False" 
                        Margin="0,70,0,0" 
                        CanUserSortColumns="False" 
                        HorizontalScrollBarVisibility="Visible" 
                        VerticalScrollBarVisibility="Visible" 
                        CanUserDeleteRows="False" 
                        CanUserAddRows="False" 
                        IsReadOnly="True" 
                        SelectionChanged="dgCronMS_SelectionChanged" 
                        MouseDoubleClick="dgCron_MouseDoubleClick" 
                        RowHeight="20" 
                        SelectionMode="Single"
                    >
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="orderMS" Header="N п\п" Width="45" Binding="{Binding Path=order}" />
                            <DataGridTextColumn x:Name="taskMS" Header="Задача" Width="150" Binding="{Binding Path=task}" />
                            <DataGridTextColumn x:Name="application_nameMS" Header="Application Name" Width="150" Binding="{Binding Path=application_name}" />
                            <DataGridTextColumn x:Name="commentMS" Header="Описание" Width="150" Binding="{Binding Path=comment}" />
                            <DataGridTextColumn x:Name="commandMS" Header="Задание" Width="150" Binding="{Binding Path=command}" />
                            <DataGridTextColumn x:Name="scheduleMS" Header="Расписание" Width="150" Binding="{Binding Path=schedule}" />
                            <DataGridTextColumn x:Name="stateMS" Header="Статус" Width="60" Binding="{Binding Path=state}" />
                            <DataGridCheckBoxColumn x:Name="istempMS" Header="Temp?" Width="60" Binding="{Binding Path=isTemp}" />
                            <DataGridTextColumn x:Name="databaseMS" Header="Целевая БД" Width="90" Binding="{Binding Path=database}" />
                            <DataGridTextColumn x:Name="stageMS" Header="Тип БД" Width="60" Binding="{Binding Path=stage}" />
                            <DataGridTextColumn x:Name="regions_strMS" Header="Регионы" Width="150" Binding="{Binding Path=regions_str}" />
                            <DataGridTextColumn x:Name="exclude_regions_strMS" Header="Кроме регионов" Width="150" Binding="{Binding Path=exclude_regions_str}" />
                            <DataGridTextColumn x:Name="timeoutMS" Header="Таймаут,сек" Width="80" Binding="{Binding Path=timeout}" />
                            <DataGridTextColumn x:Name="teamMS" Header="Команда" Width="60" Binding="{Binding Path=team}" />
                            <DataGridTextColumn x:Name="hostsMS" Header="Параллельность" Width="60" Binding="{Binding Path=hosts}" />
                            <DataGridTextColumn x:Name="checkMS" Header="Проверочный запрос" Width="150" Binding="{Binding Path=check}" />
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Выбрать задание" Click="btChoose_Click" />
                                <Separator/>
                                <MenuItem Header="Добавить задание" Click="btAdd_Click" />
                                <MenuItem Header="Клонировать задание" Click="btCopy_Click" />
                                <MenuItem Header="Изменить задание" Click="btEdit_Click" />
                                <MenuItem Header="Удалить задание" Click="btDel_Click" />
                                <Separator/>
                                <MenuItem Header="Сгенерировать и сохранить JSON" Click="btGenJSON_MS_Click" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem x:Name="tiCronPG" Header="Задания для PostgreSQL (ЕЦП)" KeyDown="tiCronPG_KeyDown" GotFocus="tiCronPG_GotFocus">
                <Grid Background="#FFE5E5E5">

                    <Button x:Name="btUpPG" ToolTip="Поднять строку выше" Click="btUpPG_Click" HorizontalAlignment="Left" Margin="10,12,0,0" VerticalAlignment="Top" Width="23" Height="23">
                        <Image Source="../Images/up.png"></Image>
                    </Button>

                    <Button x:Name="btDownPG" ToolTip="Опустить строку ниже" Click="btDownPG_Click" HorizontalAlignment="Left" Margin="40,12,0,0" VerticalAlignment="Top" Width="23" Height="23">
                        <Image Source="../Images/down.png"></Image>
                    </Button>

                    <Button x:Name="btChoosePG" Content="Выбрать" HorizontalAlignment="Left" Margin="70,10,0,0" Width="130" Height="25" VerticalAlignment="Top" Click="btChoose_Click"/>
                    <Button x:Name="btAddPG" Content="Добавить" HorizontalAlignment="Left" Margin="210,10,0,0" Width="130" Height="25" VerticalAlignment="Top" Click="btAdd_Click"/>
                    <Button x:Name="btCopyPG" Content="Клонировать" HorizontalAlignment="Left" Margin="350,10,0,0" Width="90" Height="25" VerticalAlignment="Top" Click="btCopy_Click" />
                    <Button x:Name="btEditPG" Content="Изменить" HorizontalAlignment="Left" Margin="450,10,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btEdit_Click"/>
                    <Button x:Name="btDelPG" Content="Удалить" HorizontalAlignment="Left" Margin="540,10,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btDel_Click" />
                    <Button x:Name="btGenJSON_PG" Content="Сгенерировать и сохранить JSON (F8)" HorizontalAlignment="Left" Margin="630,10,0,0" Width="300" Height="25" VerticalAlignment="Top" Click="btGenJSON_PG_Click"/>

                    <Label Content="Фильтр:" HorizontalAlignment="Left" Margin="10,40,0,0" Height="24" VerticalAlignment="Top"/>
                    <local:HistoryTextBox x:Name="tbFilterPG" HorizontalAlignment="Left" Height="24" Margin="70,40,0,0" VerticalAlignment="Top" Width="416" KeyDown="tbFilterPG_KeyDown" SelectionChanged="tbFilterPG_SelectionChanged" LostFocus="tbFilterPG_LostFocus" DropDownClosed="tbFilterPG_DropDownClosed"/>
                    <Button x:Name="btDelFilterPG" Content="X" HorizontalAlignment="Left" Height="23" Margin="493,40,0,0" VerticalAlignment="Top" Width="23" Click="btDelFilterPG_Click" ToolTip="Очистить фильтр"/>
                    <Button x:Name="btFilterPG" Content="Искать" HorizontalAlignment="Left" Margin="540,39,0,0" Width="80" Height="25" VerticalAlignment="Top" Click="btFilterPG_Click"/>

                    <DataGrid x:Name="dgCronPG"
                        AutoGenerateColumns="False" 
                        Margin="0,70,0,0" 
                        CanUserSortColumns="False" 
                        HorizontalScrollBarVisibility="Visible" 
                        VerticalScrollBarVisibility="Visible" 
                        CanUserDeleteRows="False" 
                        CanUserAddRows="False" 
                        IsReadOnly="True" 
                        SelectionChanged="dgCronPG_SelectionChanged" 
                        MouseDoubleClick="dgCron_MouseDoubleClick" 
                        RowHeight="20" 
                        SelectionMode="Single"
                    >
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="orderPG" Header="N п\п" Width="45" Binding="{Binding Path=order}" />
                            <DataGridTextColumn x:Name="taskPG" Header="Задача" Width="150" Binding="{Binding Path=task}" />
                            <DataGridTextColumn x:Name="application_namePG" Header="Application Name" Width="150" Binding="{Binding Path=application_name}" />
                            <DataGridTextColumn x:Name="commentPG" Header="Описание" Width="150" Binding="{Binding Path=comment}" />
                            <DataGridTextColumn x:Name="commandPG" Header="Задание" Width="150" Binding="{Binding Path=command}" />
                            <DataGridTextColumn x:Name="schedulePG" Header="Расписание" Width="150" Binding="{Binding Path=schedule}" />
                            <DataGridTextColumn x:Name="statePG" Header="Статус" Width="60" Binding="{Binding Path=state}" />
                            <DataGridCheckBoxColumn x:Name="istempPG" Header="Temp?" Width="60" Binding="{Binding Path=isTemp}" />
                            <DataGridTextColumn x:Name="databasePG" Header="Целевая БД" Width="90" Binding="{Binding Path=database}" />
                            <DataGridTextColumn x:Name="stagePG" Header="Тип БД" Width="60" Binding="{Binding Path=stage}" />
                            <DataGridTextColumn x:Name="regions_strPG" Header="Регионы" Width="150" Binding="{Binding Path=regions_str}" />
                            <DataGridTextColumn x:Name="exclude_regions_strPG" Header="Кроме регионов" Width="150" Binding="{Binding Path=exclude_regions_str}" />
                            <DataGridTextColumn x:Name="timeoutPG" Header="Таймаут,сек" Width="80" Binding="{Binding Path=timeout}" />
                            <DataGridTextColumn x:Name="teamPG" Header="Команда" Width="60" Binding="{Binding Path=team}" />
                            <DataGridTextColumn x:Name="hostsPG" Header="Параллельность" Width="60" Binding="{Binding Path=hosts}" />
                            <DataGridTextColumn x:Name="checkPG" Header="Проверочный запрос" Width="150" Binding="{Binding Path=check}" />
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Выбрать задание" Click="btChoose_Click" />
                                <Separator/>
                                <MenuItem Header="Добавить задание" Click="btAdd_Click" />
                                <MenuItem Header="Клонировать задание" Click="btCopy_Click" />
                                <MenuItem Header="Изменить задание" Click="btEdit_Click" />
                                <MenuItem Header="Удалить задание" Click="btDel_Click" />
                                <Separator/>
                                <MenuItem Header="Сгенерировать и сохранить JSON" Click="btGenJSON_PG_Click" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
