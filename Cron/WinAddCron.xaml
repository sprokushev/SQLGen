<Window x:Name="winAddCron" x:Class="SQLGen.WinAddCron"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        xmlns:wpfCronExpressionUi="clr-namespace:WpfCronExpressionUI;assembly=WpfCronExpressionUI"
        mc:Ignorable="d"
        Title="WinAddCron" Height="810" Width="950" Activated="winAddCron_Activated" Closed="winAddCron_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">
        <Label Content="Номер задачи:" HorizontalAlignment="Left" Margin="10,9,0,0" VerticalAlignment="Top"/>
        <local:HistoryTextBox x:Name="tbTask" HorizontalAlignment="Left" Height="24" Margin="220,12,0,0" VerticalAlignment="Top" Width="370" Text="{Binding Path=task, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="tbTask_SelectionChanged" LostFocus="tbTask_LostFocus" DropDownClosed="tbTask_DropDownClosed"/>

        <Label Content="Тип региона по типу основной БД:" HorizontalAlignment="Left" Margin="10,38,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbDBRegions" HorizontalAlignment="Left" Margin="220,40,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListDBRegions}" SelectedItem="{Binding Path=DBRegion, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="False"/>

        <Label Content="Наименование задания:" HorizontalAlignment="Left" Margin="10,66,0,0" VerticalAlignment="Top"/>
        <local:HistoryTextBox x:Name="tbApplicationName" HorizontalAlignment="Left" Height="24" Margin="220,68,0,0" VerticalAlignment="Top" Width="370" Text="{Binding Path=application_name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="tbApplicationName_SelectionChanged" LostFocus="tbApplicationName_LostFocus" DropDownClosed="tbApplicationName_DropDownClosed"/>

        <Label Content="Описание задания:" HorizontalAlignment="Left" Margin="10,94,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbComment" HorizontalAlignment="Left" Margin="10,120,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="60" VerticalAlignment="Top" Width="580" Text="{Binding Path=comment, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True"/>

        <Label Content="Команда или скрипт для задания:" HorizontalAlignment="Left" Margin="10,182,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbCommand" HorizontalAlignment="Left" Margin="10,210,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="120" VerticalAlignment="Top" Width="580" Text="{Binding Path=command, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True"/>

        <Label Content="Расписание задания:" HorizontalAlignment="Left" Margin="10,332,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbSchedule" HorizontalAlignment="Left" Margin="10,360,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="60" VerticalAlignment="Top" Width="580" Text="{Binding Path=schedule, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True"/>

        <Button x:Name="btSetSchedule" ToolTip="Открыть калькулятор расписания cron" Margin="200,334,0,0" Width="21" Click="btSetSchedule_Click" HorizontalAlignment="Left" Height="21" VerticalAlignment="Top" IsEnabled="{Binding Path=hasWhenTimeout}">
            <Image Source="../Images/schedule.png" ToolTip="Открыть калькулятор расписания cron"/>
        </Button>

        <Label Content="Статус задания:" HorizontalAlignment="Left" Margin="10,422,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbState" HorizontalAlignment="Left" Margin="220,424,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListStates}" SelectedItem="{Binding Path=State, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Целевая БД:" HorizontalAlignment="Left" Margin="10,448,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbDatabases" HorizontalAlignment="Left" Margin="220,450,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListDatabases}" SelectedItem="{Binding Path=Database, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="cbDatabases_SelectionChanged"/>

        <Label Content="Тип целевой БД:" HorizontalAlignment="Left" Margin="10,474,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbStages" HorizontalAlignment="Left" Margin="220,476,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListStages}" SelectedItem="{Binding Path=Stage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <CheckBox x:Name="cbTimeout" Content="Добавить таймаут" HorizontalAlignment="Left" Margin="10,502,0,0" VerticalAlignment="Top" IsChecked="{Binding Path=hasTimeout, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBox x:Name="tbHour" HorizontalAlignment="Left" Margin="145,502,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_hour, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="часов" HorizontalAlignment="Left" Margin="215,498,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="tbMinute" HorizontalAlignment="Left" Margin="275,502,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_minute, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="минут" HorizontalAlignment="Left" Margin="345,498,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="tbSecond" HorizontalAlignment="Left" Margin="405,502,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_second, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="секунд" HorizontalAlignment="Left" Margin="475,498,0,0" VerticalAlignment="Top"/>

        <Label Content="Параллельность:" HorizontalAlignment="Left" Margin="10,524,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbHosts" HorizontalAlignment="Left" Margin="220,526,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListHosts}" SelectedItem="{Binding Path=Hosts, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Проверочный запрос:" HorizontalAlignment="Left" Margin="10,544,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbCheck" HorizontalAlignment="Left" Margin="10,568,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="120" VerticalAlignment="Top" Width="580" Text="{Binding Path=check, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" TextChanged="tbCheck_TextChanged" />

        <Label Content="Команда:" HorizontalAlignment="Left" Margin="10,690,0,0" VerticalAlignment="Top"/>
        <local:HistoryTextBox x:Name="tbTeam" HorizontalAlignment="Left" Height="24" Margin="220,692,0,0" VerticalAlignment="Top" Width="370" Text="{Binding Path=team, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="tbTeam_SelectionChanged" LostFocus="tbTeam_LostFocus" DropDownClosed="tbTeam_DropDownClosed"/>

        <CheckBox x:Name="cbIsTemp" Content="Временное задание" HorizontalAlignment="Left" Margin="10,718,0,0" VerticalAlignment="Top" IsChecked="{Binding Path=isTemp, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Целевые регионы:" HorizontalAlignment="Left" Margin="619,10,0,0" VerticalAlignment="Top"/>

        <ListBox x:Name="lcbRegions" Height="180" HorizontalAlignment="Left" Margin="619,41,0,0" VerticalAlignment="Top" Width="295" ItemsSource="{Binding lcbListRegions}" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding TheText}" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Label Content="Кроме регионов:" HorizontalAlignment="Left" Margin="619,228,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="lcbExcludeRegions" Height="180" HorizontalAlignment="Left" Margin="619,258,0,0" VerticalAlignment="Top" Width="295" ItemsSource="{Binding lcbListExcludeRegions}" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding TheText}" Unchecked="CheckBox_Unchecked_1" Checked="CheckBox_Checked_1"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Label Content="Действия при обновлении:" HorizontalAlignment="Left" Margin="619,438,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbDescription" HorizontalAlignment="Left" Margin="619,468,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="250" VerticalAlignment="Top" Width="295" IsReadOnly="True" Text="{Binding Path=Description, Mode=OneWay}"/>

        <Button x:Name="btSave" Content="Сохранить" Margin="98,746,0,0" Click="btSave_Click" HorizontalAlignment="Left" Width="150" VerticalAlignment="Top" IsDefault="True"/>
        <Button x:Name="btCancel" Content="Отмена" Margin="374,746,0,0" Click="btCancel_Click" HorizontalAlignment="Left" Width="150" VerticalAlignment="Top" IsCancel="True"/>

    </Grid>
</Window>
