<Window x:Name="winQuery" x:Class="SQLGen.WinQuery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        mc:Ignorable="d"
        Title="WinQuery" Height="800" Width="1650" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen" Activated="winQuery_Activated" Closed="winQuery_Closed">

    <Grid x:Name="mainGrid">
        <TabControl>
            <TabItem x:Name="tiSQL" Header="SQL" KeyDown="tiSQL_KeyDown">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="200"></RowDefinition>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">

                        <ToolBar x:Name="toolbarHistorySQL" DockPanel.Dock="Top" Background="#FFE5E5E5" >
                            <Label Content="История запросов:" HorizontalAlignment="Left" Height="24" Width="120" />
                            <local:HistoryTextBox x:Name="cbHistorySQLQuery" HorizontalAlignment="Left" Height="24" Width="Auto" SelectionChanged="cbHistorySQLQuery_SelectionChanged" IsEditable="False" IsReadOnly="True" MinWidth="1000"/>
                        </ToolBar>

                        <ToolBar x:Name="toolbarExecSQL" DockPanel.Dock="Top" Background="#FFE5E5E5">
                            <Label Content="Подключение:" HorizontalAlignment="Left" Height="24" Width="95"/>
                            <ComboBox x:Name="cbConnectSQL" HorizontalAlignment="Left" Height="24" Width="450" LostFocus="cbConnectSQL_LostFocus"/>
                            <Button x:Name="btAddConnectSQL" HorizontalAlignment="Left" Height="24" Width="24" ToolTip="Добавить новое подключение или переоткрыть текущее" Click="btAddConnectSQL_Click" TabIndex="2">
                                <Image Source="../Images/plus.png"></Image>
                            </Button>
                            <Separator/>
                            <Button x:Name="btSelectIUD" HorizontalAlignment="Left" Height="24" Width="172" ToolTip="Выполнить скрипт (F5)" Click="btSelectIUD_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="../Images/Start.png"></Image>
                                    <TextBlock>Выполнить скрипт (F5)</TextBlock>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btLoadXLS" HorizontalAlignment="Left" Height="24" Width="190" ToolTip="Загрузить из файла Excel" Click="btLoadXLS_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="../Images/Excel.png"></Image>
                                    <TextBlock>Загрузить из файла Excel</TextBlock>
                                </StackPanel>
                            </Button>
                        </ToolBar>

                        <ToolBar x:Name="toolbarSQL" DockPanel.Dock="Top" Background="#FFE5E5E5">
                            <ComboBox Name="cbSQLFontFamily" Width="150" Focusable="False" IsTabStop="False" />
                            <ComboBox Name="cbSQLFontSize" Width="50" IsEditable="True" Focusable="False" IsTabStop="False" />
                        </ToolBar>
                        <Label x:Name="lbSQLFilename" Content="" DockPanel.Dock="Top" Visibility="Collapsed"/>
                        <local:SQLEditor x:Name="tbSQL" TextChanged="tbSQL_TextChanged" />
                    </DockPanel>

                    <GridSplitter Grid.Row="1" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="False" />

                    <TextBox x:Name="tbSQLMessages" Grid.Row="2" TextWrapping="Wrap" IsReadOnly="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" />
                </Grid>
            </TabItem>

            <TabItem x:Name="tiData" Header="Данные" KeyDown="tiGrid_KeyDown">
                <Grid x:Name="gridData" Background="#FFE5E5E5">
                    <DataGrid x:Name="dgData" Margin="0,1,0,120" 
                              IsReadOnly="True" 
                              AutoGeneratingColumn="dgData_AutoGeneratingColumn" 
                              CanUserSortColumns="False" 
                              CanUserReorderColumns="False"
                              LoadingRow="DataGrid_LoadingRow" SelectionUnit="Cell"
                              >
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Скопировать имя поля" Click="HeaderCopy_Click" />
                                <MenuItem Header="Скопировать значение поля" Click="CellCopy_Click" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <Grid Margin="20,0,20,96" VerticalAlignment="Bottom">
                        <ProgressBar x:Name="pbProgress" Minimum="0" Maximum="100" Height="20"/>
                        <TextBlock Text="{Binding Value, ElementName=pbProgress, StringFormat=\{0:0\}%}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Label Content="Имя таблицы:" HorizontalAlignment="Left" Margin="3,0,0,65" VerticalAlignment="Bottom" Height="25"/>
                    <local:HistoryTextBox x:Name="tbTableNameSQL" HorizontalAlignment="Left" Height="22" Margin="94,0,0,65" VerticalAlignment="Bottom" Width="317" LostFocus="tbTableNameSQL_LostFocus" KeyDown="tbTableNameSQL_KeyDown" SelectionChanged="tbTableNameSQL_SelectionChanged" DropDownClosed="tbTableNameSQL_DropDownClosed"/>
                    <Label Content="Уникальные поля (через запятую):" HorizontalAlignment="Left" Margin="416,0,0,65" VerticalAlignment="Bottom" Width="213"/>
                    <TextBox x:Name="tbPrimaryKey" HorizontalAlignment="Left" Height="26" Margin="634,0,0,65" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="342" Text="{Binding UniqueKey, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Целевой проект GIT:" Margin="4,0,0,35" Height="26" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="124"/>
                    <ComboBox x:Name="cbGITProject" HorizontalAlignment="Left" Margin="133,0,0,37" VerticalAlignment="Bottom" Width="275" SelectionChanged="cbGITProject_SelectionChanged" />
                    <Label Content="Тип скрипта:" HorizontalAlignment="Left" Margin="413,0,0,35" Height="25" VerticalAlignment="Bottom"/>
                    <ComboBox x:Name="cbScriptType" HorizontalAlignment="Left" Margin="493,0,0,37" VerticalAlignment="Bottom" Width="206" SelectedIndex="0" SelectionChanged="cbScriptType_SelectionChanged" >
                        <ComboBoxItem Content="INSERT"/>
                        <ComboBoxItem Content="INSERT (VALUES)"/>
                        <ComboBoxItem Content="INSERT (TMP)"/>
                        <ComboBoxItem Content="INSERT (BULK/COPY TABLE)"/>
                        <ComboBoxItem Content="INSERT (BULK/COPY VIEW)"/>
                        <ComboBoxItem Content="INSERT+UPDATE"/>
                        <ComboBoxItem Content="INSERT+UPDATE (TMP)"/>
                        <ComboBoxItem Content="UPDATE"/>
                        <ComboBoxItem Content="DELETE"/>
                        <ComboBoxItem Content="Шаблон"/>
                    </ComboBox>
                    <ComboBox x:Name="cbInsUpdDTType" HorizontalAlignment="Left" Margin="192,0,0,8" VerticalAlignment="Bottom" Width="279" SelectedIndex="0" SelectionChanged="cbInsUpdDTType_SelectionChanged" Height="22" >
                        <ComboBoxItem Content="insDT/updDT - оставить без изменений"/>
                        <ComboBoxItem Content="insDT/updDT - функция (getdate() или localtimestamp)"/>
                        <ComboBoxItem Content="insDT/updDT - переменная = (dbo.tzgetdate() или localtimestamp)"/>
                    </ComboBox>
                    <Button x:Name="btGenerateIUD" Content="Сгенерировать скрипт (F5)" HorizontalAlignment="Left" Margin="1102,0,0,65" Width="188" Height="25" VerticalAlignment="Bottom" Click="btGenerateIUD_Click" />
                    <Button x:Name="btGenerateIUDFile" Content="Сгенерировать в файл (F8)" HorizontalAlignment="Left" Margin="1297,0,0,65" Width="191" Height="25" VerticalAlignment="Bottom" Click="btGenerateIUDFile_Click" />
                    <Button x:Name="btCancel" Content="Остановить (Esc)" HorizontalAlignment="Left" Margin="1360,0,0,35" Width="128" Height="25" VerticalAlignment="Bottom" Click="btCancel_Click" IsCancel="True" />
                    <CheckBox x:Name="isAddGO" Content="Добавить GO" HorizontalAlignment="Left" Margin="900,0,0,39" VerticalAlignment="Bottom" Height="15" Width="Auto" IsChecked="{Binding isAddGO, UpdateSourceTrigger=PropertyChanged}" Checked="isAddGO_Checked" />
                    <CheckBox x:Name="isAddDel" Content="Добавить Признак удаления" HorizontalAlignment="Left" Margin="1010,0,0,39" VerticalAlignment="Bottom" Height="15" Width="Auto" IsChecked="{Binding isAddDel, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox x:Name="isRegion" Content="Добавить проверку на региональность" HorizontalAlignment="Left" Margin="992,0,0,10" VerticalAlignment="Bottom" Width="Auto" Height="15" Checked="isRegion_Checked" Unchecked="isRegion_Unchecked" />
                    <ComboBox x:Name="cbRegion" HorizontalAlignment="Left" Margin="1244,0,0,8" Width="205" VerticalAlignment="Bottom" Height="22" SelectionChanged="cbRegion_SelectionChanged" />
                    <Button x:Name="btExcel" Content="Выгрузить в Excel" HorizontalAlignment="Left" Margin="1495,0,0,65" Width="126" Click="btExcel_Click" Height="25" VerticalAlignment="Bottom" />
                    <Button x:Name="btTable" Content="Открыть Таблицу" HorizontalAlignment="Left" Margin="1495,0,0,35" Width="126" Height="25" VerticalAlignment="Bottom" Click="btTable_Click" />
                    <ComboBox x:Name="cbAddFK" HorizontalAlignment="Left" Margin="720,0,0,8" Width="250" VerticalAlignment="Bottom" Height="22" SelectedIndex="0" SelectionChanged="cbAddFK_SelectionChanged" >
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Добавить INSERT внешних ключей"/>
                        <ComboBoxItem Content="Добавить EXISTS внешних ключей"/>
                    </ComboBox>
                    <Button x:Name="btChooseFields" Content="Выбрать поля" HorizontalAlignment="Left" Margin="990,0,0,65" Width="105" Height="25" VerticalAlignment="Bottom" Click="btChooseFields_Click" />
                    <CheckBox x:Name="isUseInsertUpdate" Content="INSERT+UPDATE" HorizontalAlignment="Left" Margin="600,0,0,10" VerticalAlignment="Bottom" Height="15" Width="Auto" Unchecked="isUseInsertUpdate_Unchecked" Checked="isUseInsertUpdate_Checked" />
                    <CheckBox x:Name="isAddCheckUnique" Content="Check Unique" HorizontalAlignment="Left" Margin="491,0,0,10" VerticalAlignment="Bottom" Height="15" Width="Auto" Unchecked="isAddCheckUnique_Unchecked" Checked="isAddCheckUnique_Checked" />
                    <CheckBox x:Name="isAddEmptyString" Content="Добавлять пустую строку" HorizontalAlignment="Left" Margin="10,0,0,10" VerticalAlignment="Bottom" Height="15" Width="Auto" IsChecked="{Binding isAddEmptyString, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox x:Name="isAddCreateTable" Content="Добавить создание таблицы" HorizontalAlignment="Left" Margin="710,0,0,39" VerticalAlignment="Bottom" Height="15" Width="Auto" IsChecked="{Binding isAddCreateTable, UpdateSourceTrigger=PropertyChanged}" />
                    <CheckBox x:Name="isUpdateLocalDBList" Content="UPDATE stg.LocalDBList" HorizontalAlignment="Left" Margin="1200,0,0,39" VerticalAlignment="Bottom" Height="15" Width="Auto" IsChecked="{Binding isUpdateLocalDBList, UpdateSourceTrigger=PropertyChanged}" />
                    <Label x:Name="lbCount" Content="Строк:" HorizontalAlignment="Left" Margin="1465,0,0,4" Height="25" VerticalAlignment="Bottom"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="tiScriptIUD" Header="Script" KeyDown="tiScriptIUD_KeyDown">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="200"></RowDefinition>
                        <RowDefinition Height="25"></RowDefinition>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">

                        <ToolBar x:Name="toolbarExecScriptIUD" DockPanel.Dock="Top" Background="#FFE5E5E5">
                            <Button x:Name="btSaveIUD" HorizontalAlignment="Left" Height="24" Width="175" ToolTip="Сохранить в файл (F8)" Click="btSaveIUD_Click" >
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="../Images/SaveSQL.png"></Image>
                                    <TextBlock>Сохранить в файл (F8)</TextBlock>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btClipboardIUD" HorizontalAlignment="Left" Height="24" Width="150" ToolTip="В буфер обмена" Click="btClipboardIUD_Click" >
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="../Images/clipboard.png"></Image>
                                    <TextBlock>В буфер обмена</TextBlock>
                                </StackPanel>
                            </Button>

                            <Label Content="Подключение:" HorizontalAlignment="Left" Height="24" Width="95"/>
                            <ComboBox x:Name="cbConnectTarget" HorizontalAlignment="Left" Height="24" Width="450" />
                            <Button x:Name="btAddConnectTarget" HorizontalAlignment="Left"  Height="24" Width="24" ToolTip="Добавить новое подключение или переоткрыть текущее" Click="btAddConnectTarget_Click" >
                                <Image Source="../Images/plus.png"></Image>
                            </Button>

                            <Separator/>

                            <Button x:Name="btExecScriptIUD" HorizontalAlignment="Left" Height="24" Width="190" ToolTip="Выполнить скрипт (F5)" Click="btExecScriptIUD_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="../Images/Start.png"></Image>
                                    <TextBlock>Выполнить скрипт (F5)</TextBlock>
                                </StackPanel>
                            </Button>
                        </ToolBar>

                        <ToolBar x:Name="toolbarScriptIUD" DockPanel.Dock="Top" Background="#FFE5E5E5">
                            <ComboBox Name="cbScriptIUDFontFamily" Width="150" Focusable="False" IsTabStop="False" />
                            <ComboBox Name="cbScriptIUDFontSize" Width="50" IsEditable="True" Focusable="False" IsTabStop="False" />
                        </ToolBar>

                        <Label x:Name="lbScriptIUDFilename" Content="" DockPanel.Dock="Top" Visibility="Collapsed"/>
                        <local:SQLEditor x:Name="tbScriptIUD" TextChanged="tbScriptIUD_TextChanged" />
                    </DockPanel>

                    <GridSplitter Grid.Row="1" Height="3" HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="False" />

                    <Grid Grid.Row="2" Background="#FFE5E5E5">
                        <TabControl >
                            <TabItem x:Name="tiScriptIUDMessages" Header="Сообщения">
                                <TextBox x:Name="tbScriptIUDMessages" TextWrapping="Wrap" IsReadOnly="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" />
                            </TabItem>
                            <TabItem x:Name="tiScriptIUDResults" Header="Результаты">
                                <DataGrid x:Name="dgScriptIUDResults" 
                                          IsReadOnly="False" 
                                          CanUserSortColumns="False" 
                                          CanUserReorderColumns="False" 
                                          AutoGeneratingColumn="dgScriptIUDResults_AutoGeneratingColumn" 
                                          VerticalScrollBarVisibility="Visible" 
                                          HorizontalScrollBarVisibility="Visible" 
                                          CanUserAddRows="False" 
                                          CanUserDeleteRows="False" 
                                          ScrollViewer.CanContentScroll="True" 
                                          SelectionUnit="Cell" 
                                          LoadingRow="DataGrid_LoadingRow"
                                          />
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <Label x:Name="lbScriptIUDStatus" Grid.Row="3" Background="#FFE5E5E5" Content="Кол-во записей: " HorizontalContentAlignment="Right"/>

                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    <Window.TaskbarItemInfo >
        <TaskbarItemInfo x:Name="taskBarItem" ProgressState="Normal"/>
    </Window.TaskbarItemInfo>
</Window>
