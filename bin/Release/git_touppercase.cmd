rem ---------------------------------------------------------------------
rem процедура перевода в upper case
:touppercase
if not defined %~1 exit /b
for %%a in ("a=A" "b=B" "c=C" "d=D" "e=E" "f=F" "g=G" "h=H" "i=I" "j=J" "k=K" "l=L" "m=M" "n=N" "o=O" "p=P" "q=Q" "r=R" "s=S" "t=T" "u=U" "v=V" "w=W" "x=X" "y=Y" "z=Z") do (
call set %~1=%%%~1:%%~a%%
)
goto :eof
rem ---------------------------------------------------------------------
