<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        xmlns:controlzex="urn:controlzex" x:Class="SQLGen.WinInfo"
        mc:Ignorable="d" Height="500" Width="900" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen" Activated="Window_Activated" Closed="Window_Closed">
    <Grid x:Name="mainGrid" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <DockPanel>
            <ToolBar x:Name="toolbarInfo" DockPanel.Dock="Top" TabIndex="2" Background="#00FFFFFF">
                <ComboBox Name="cbInfoFontFamily" Width="150" Focusable="False" IsTabStop="False" TabIndex="3" />
                <ComboBox Name="cbInfoFontSize" Width="50" IsEditable="True" Focusable="False" IsTabStop="False" TabIndex="4" />
            </ToolBar>
            <local:SQLEditor x:Name="tbInfo" Margin="0,0,0,40" KeyDown="tbInfo_KeyDown" PreviewKeyDown="tbInfo_PreviewKeyDown"/>
        </DockPanel>
        <Button x:Name="btOk" Content="Закрыть" Margin="294,0,0,10" IsDefault="True" Height="20" VerticalAlignment="Bottom" MinWidth="72" MinHeight="20" Width="72" Click="btOk_Click" IsCancel="True" HorizontalAlignment="Left"/>
        <Button x:Name="btExternal" Content="Открыть во внешнем редакторе" Margin="400,0,0,10" IsDefault="True" Height="20" VerticalAlignment="Bottom" MinWidth="72" MinHeight="20" Width="261" Click="btExternal_Click" HorizontalAlignment="Left"/>
    </Grid>
</Window>