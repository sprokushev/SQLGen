<Window x:Name="winAddDeployment" x:Class="SQLGen.WinAddDeployment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SQLGen"
        xmlns:wpfCronExpressionUi="clr-namespace:WpfCronExpressionUI;assembly=WpfCronExpressionUI"
        mc:Ignorable="d"
        Title="WinAddDeployment" Height="980" Width="950" Activated="winAddDeployment_Activated" Closed="winAddDeployment_Closed" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Visible" WindowStartupLocation="CenterScreen"
        >
    <Grid x:Name="mainGrid" Background="#FFE5E5E5">
        <Label Content="Номер задачи:" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbTask" HorizontalAlignment="Left" Margin="220,14,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="370" Text="{Binding Path=task, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" LostFocus="tbTask_LostFocus"/>

        <Label Content="Тип региона по типу основной БД:" HorizontalAlignment="Left" Margin="10,33,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbDBRegions" HorizontalAlignment="Left" Margin="220,34,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListDBRegions}" SelectedItem="{Binding Path=DBRegion, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="False"/>

        <Label Content="Когда выполнять?:" HorizontalAlignment="Left" Margin="10,56,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbPositions" HorizontalAlignment="Left" Margin="220,58,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListPositions}" SelectedItem="{Binding Path=Position, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Тип автоматизации:" HorizontalAlignment="Left" Margin="10,80,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbTypes" HorizontalAlignment="Left" Margin="220,82,0,0" VerticalAlignment="Top" Width="370" ItemsSource="{Binding ListTypes}" SelectedItem="{Binding Path=Type, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="cbTypes_SelectionChanged"/>

        <Button x:Name="btFind" Content="Найти скрипт или файл" Margin="220,110,0,0" Click="btFind_Click" HorizontalAlignment="Left" Width="170" VerticalAlignment="Top" IsDefault="True" IsEnabled="{Binding Path=isFindEnabled}"/>

        <Label Content="Скрипт:" HorizontalAlignment="Left" Margin="10,110,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbScript" HorizontalAlignment="Left" Margin="10,134,0,0" VerticalScrollBarVisibility="Visible" TextWrapping="Wrap" Height="120" VerticalAlignment="Top" Width="600" Text="{Binding Path=script, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=isScriptEnabled}" TextChanged="tbScript_TextChanged"/>

        <Label Content="Файл:" HorizontalAlignment="Left" Margin="10,254,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbFile" HorizontalAlignment="Left" Height="60" Margin="10,279,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="600" Text="{Binding Path=file, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=isFileEnabled}" TextChanged="tbFile_TextChanged"/>

        <Label Content="Целевая БД:" HorizontalAlignment="Left" Margin="10,340,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbDatabases" HorizontalAlignment="Left" Margin="130,342,0,0" VerticalAlignment="Top" Width="344" ItemsSource="{Binding ListDatabases}" SelectedItem="{Binding Path=Database, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" SelectionChanged="cbDatabases_SelectionChanged"/>

        <Label Content="Тип целевой БД:" HorizontalAlignment="Left" Margin="10,364,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbStages" HorizontalAlignment="Left" Margin="130,366,0,0" VerticalAlignment="Top" Width="344" ItemsSource="{Binding ListStages}" SelectedItem="{Binding Path=Stage, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Целевые регионы:" HorizontalAlignment="Left" Margin="619,10,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="lcbRegions" Height="150" HorizontalAlignment="Left" Margin="619,41,0,0" VerticalAlignment="Top" Width="295" ItemsSource="{Binding lcbListRegions}" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding TheText}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Label Content="Кроме регионов:" HorizontalAlignment="Left" Margin="619,207,0,0" VerticalAlignment="Top"/>
        <ListBox x:Name="lcbExcludeRegions" Height="150" HorizontalAlignment="Left" Margin="619,238,0,0" VerticalAlignment="Top" Width="295" ItemsSource="{Binding lcbListExcludeRegions}" SelectionMode="Multiple">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding TheText}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Rectangle HorizontalAlignment="Left" Height="234" Margin="10,395,0,0" Stroke="Black" VerticalAlignment="Top" Width="600"/>

        <CheckBox x:Name="cbWhenFailed" Content="Блок действий в случае ошибки" HorizontalAlignment="Left" Margin="15,397,0,0" VerticalAlignment="Top" IsChecked="{Binding Path=hasWhenFailed, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Действие:" HorizontalAlignment="Left" Margin="15,415,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbWhenFailedActions" HorizontalAlignment="Left" Margin="180,417,0,0" VerticalAlignment="Top" Width="344" ItemsSource="{Binding ListActions}" SelectedItem="{Binding Path=when_failed_action, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenFailed}" SelectionChanged="cbWhenFailedActions_SelectionChanged"/>

        <Label Content="Наименование (cron):" HorizontalAlignment="Left" Margin="15,439,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenFailedName" HorizontalAlignment="Left" Margin="180,441,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_failed_name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Label Content="Команда (cron):" HorizontalAlignment="Left" Margin="15,459,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenFailedJob" HorizontalAlignment="Left" Margin="180,461,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_failed_job, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Label Content="Расписание (cron):" HorizontalAlignment="Left" Margin="15,479,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenFailedSchedule" HorizontalAlignment="Left" Margin="180,481,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_failed_schedule, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Button x:Name="btSetWhenFailedSchedule" ToolTip="Открыть калькулятор расписания cron" Margin="530,479,0,0" Width="21" Click="btSetWhenFailedSchedule_Click" HorizontalAlignment="Left" Height="21" VerticalAlignment="Top" IsEnabled="{Binding Path=hasWhenFailed}">
            <Image Source="../Images/schedule.png" ToolTip="Открыть калькулятор расписания cron"/>
        </Button>

        <Label Content="Скрипт (liquibase):" HorizontalAlignment="Left" Margin="15,499,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenFailedScript" HorizontalAlignment="Left" Margin="180,501,0,0" VerticalScrollBarVisibility="Visible" Height="60" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_failed_script, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Button x:Name="btFindWhenFailedScript" Content="Найти" Margin="530,505,0,0" Click="btFindWhenFailedScript_Click" HorizontalAlignment="Left" Width="60" VerticalAlignment="Top" IsDefault="True" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Label Content="Скрипт, если предыдущий" HorizontalAlignment="Left" Margin="15,564,0,0" VerticalAlignment="Top" Width="158"/>
        <Label Content="успешен (liquibase):" HorizontalAlignment="Left" Margin="15,580,0,0" VerticalAlignment="Top" Width="158"/>
        <TextBox x:Name="tbWhenFailedScriptAfter" HorizontalAlignment="Left" Margin="180,564,0,0" VerticalScrollBarVisibility="Visible" Height="60" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_failed_script_after, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=hasWhenFailed}"/>

        <Button x:Name="btFindWhenFailedScriptAfter" Content="Найти" Margin="530,570,0,0" Click="btFindWhenFailedScriptAfter_Click" HorizontalAlignment="Left" Width="60" VerticalAlignment="Top" IsDefault="True" IsEnabled="{Binding Path=hasWhenFailed}"/>


        <Rectangle HorizontalAlignment="Left" Height="260" Margin="10,630,0,0" Stroke="Black" VerticalAlignment="Top" Width="600"/>
        <CheckBox x:Name="cbTimeout" Content="Добавить таймаут" HorizontalAlignment="Left" Margin="15,635,0,0" VerticalAlignment="Top" IsChecked="{Binding Path=hasTimeout, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <TextBox x:Name="tbHour" HorizontalAlignment="Left" Margin="145,635,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_hour, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="часов" HorizontalAlignment="Left" Margin="215,630,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="tbMinute" HorizontalAlignment="Left" Margin="275,635,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_minute, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="минут" HorizontalAlignment="Left" Margin="345,630,0,0" VerticalAlignment="Top"/>

        <TextBox x:Name="tbSecond" HorizontalAlignment="Left" Margin="405,635,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66" PreviewTextInput="PreviewTextInput" DataObject.Pasting="TextBoxPasting" Text="{Binding Path=timeout_second, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasTimeout}"/>
        <Label Content="секунд" HorizontalAlignment="Left" Margin="475,630,0,0" VerticalAlignment="Top"/>

        <CheckBox x:Name="cbWhenTimeout" Content="Блок действий в случае превышения таймаута" HorizontalAlignment="Left" Margin="15,655,0,0" VerticalAlignment="Top" IsChecked="{Binding Path=hasWhenTimeout, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

        <Label Content="Действие:" HorizontalAlignment="Left" Margin="15,670,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbWhenTimeoutActions" HorizontalAlignment="Left" Margin="180,672,0,0" VerticalAlignment="Top" Width="344" ItemsSource="{Binding ListActions}" SelectedItem="{Binding Path=when_timeout_action, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenTimeout}" SelectionChanged="cbWhenTimeoutActions_SelectionChanged"/>

        <Label Content="Наименование (cron):" HorizontalAlignment="Left" Margin="15,696,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenTimeoutName" HorizontalAlignment="Left" Margin="180,698,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_timeout_name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Label Content="Команда (cron):" HorizontalAlignment="Left" Margin="15,718,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenTimeoutJob" HorizontalAlignment="Left" Margin="180,720,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_timeout_job, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Label Content="Расписание (cron):" HorizontalAlignment="Left" Margin="15,740,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenTimeoutSchedule" HorizontalAlignment="Left" Margin="180,742,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_timeout_schedule, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Button x:Name="btSetWhenTimeoutSchedule" ToolTip="Открыть калькулятор расписания cron" Margin="530,740,0,0" Width="21" Click="btSetWhenTimeoutSchedule_Click" HorizontalAlignment="Left" Height="21" VerticalAlignment="Top" IsEnabled="{Binding Path=hasWhenTimeout}">
            <Image Source="../Images/schedule.png" ToolTip="Открыть калькулятор расписания cron"/>
        </Button>

        <Label Content="Скрипт (liquibase):" HorizontalAlignment="Left" Margin="15,762,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="tbWhenTimeoutScript" HorizontalAlignment="Left" Margin="180,764,0,0" VerticalScrollBarVisibility="Visible" Height="60" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_timeout_script, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Button x:Name="btFindWhenTimeoutScript" Content="Найти" Margin="530,767,0,0" Click="btFindWhenTimeoutScript_Click" HorizontalAlignment="Left" Width="60" VerticalAlignment="Top" IsDefault="True" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Label Content="Скрипт, если предыдущий" HorizontalAlignment="Left" Margin="15,827,0,0" VerticalAlignment="Top" Width="158"/>
        <Label Content="успешен (liquibase):" HorizontalAlignment="Left" Margin="15,844,0,0" VerticalAlignment="Top" Width="158"/>
        <TextBox x:Name="tbWhenTimeoutScriptAfter" HorizontalAlignment="Left" Margin="180,827,0,0" VerticalScrollBarVisibility="Visible" Height="60" TextWrapping="Wrap" VerticalAlignment="Top" Width="345" Text="{Binding Path=when_timeout_script_after, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True" IsEnabled="{Binding Path=hasWhenTimeout}"/>

        <Button x:Name="btFindWhenTimeoutScriptAfter" Content="Найти" Margin="530,832,0,0" Click="btFindWhenTimeoutScriptAfter_Click" HorizontalAlignment="Left" Width="60" VerticalAlignment="Top" IsDefault="True" IsEnabled="{Binding Path=hasWhenTimeout}"/>


        <Button x:Name="btSave" Content="Сохранить" Margin="98,910,0,0" Click="btSave_Click" HorizontalAlignment="Left" Width="150" VerticalAlignment="Top" IsDefault="True"/>
        <Button x:Name="btCancel" Content="Отмена" Margin="374,910,0,0" Click="btCancel_Click" HorizontalAlignment="Left" Width="150" VerticalAlignment="Top" IsCancel="True"/>

    </Grid>
</Window>
